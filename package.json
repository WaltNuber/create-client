{
  "name": "@api-platform/create-client",
  "version": "0.10.0",
  "description": "Generate apps built with Next, Nuxt, Quasar, React, React Native, Vue or Vuetify for any API documented using Hydra or OpenAPI",
  "files": [
    "*.md",
    "docs/*.md",
    "lib",
    "src",
    "templates"
  ],
  "type": "module",
  "exports": "./lib/index.js",
  "repository": "api-platform/create-client",
  "homepage": "https://github.com/api-platform/create-client",
  "bugs": "https://github.com/api-platform/create-client/issues",
  "author": "Kévin Dunglas",
  "license": "MIT",
  "devDependencies": {
    "@babel/cli": "^7.29.7",
    "@babel/core": "^7.29.7",
    "@babel/eslint-parser": "^7.29.7",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-export-default-from": "^7.29.7",
    "@babel/plugin-transform-flow-strip-types": "^7.29.7",
    "@babel/plugin-transform-runtime": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@playwright-testing-library/test": "4.5.0",
    "@playwright/test": "^1.60.0",
    "babel-jest": "^29.7.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^8.10.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^4.2.5",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "jest-light-runner": "^0.4.1",
    "lint-staged": "^13.3.0",
    "start-server-and-test": "^1.15.5",
    "tmp": "^0.2.7"
  },
  "dependencies": {
    "@api-platform/api-doc-parser": "^0.16.10",
    "@babel/runtime": "^7.29.7",
    "chalk": "^5.6.2",
    "commander": "^10.0.1",
    "esutils": "^2.0.3",
    "handlebars": "^4.7.9",
    "handlebars-helpers": "^0.10.0",
    "isomorphic-fetch": "^3.0.0",
    "mkdirp": "^2.1.6",
    "prettier": "^2.8.8",
    "sprintf-js": "^1.1.3"
  },
  "scripts": {
    "build": "babel src -d lib --ignore '*.test.js' && chmod +x lib/index.js",
    "prepublishOnly": "pnpm run build",
    "prepare": "pnpm run build",
    "test": "jest src",
    "lint": "eslint src",
    "fix": "eslint --fix src",
    "eslint-check": "eslint-config-prettier src/index.js",
    "lint-staged": "lint-staged",
    "watch": "babel --watch src -d lib --ignore '*.test.js'",
    "test-gen": "rm -rf ./tmp && pnpm run build && ./testgen.sh",
    "test-gen-openapi3": "rm -rf ./tmp && pnpm run build && ENTRYPOINT=https://demo.api-platform.com/docs.json FORMAT=openapi3 ./testgen.sh",
    "test-gen-custom": "rm -rf ./tmp && pnpm run build && babel src/generators/ReactGenerator.js src/generators/BaseGenerator.js -d ./tmp/gens && cp -r ./templates/react ./templates/react-common ./templates/entrypoint.js ./tmp/gens && ./lib/index.js https://demo.api-platform.com ./tmp/react-custom -g \"$(pwd)/tmp/gens/ReactGenerator.js\" -t ./tmp/gens",
    "test-gen-env": "rm -rf ./tmp && pnpm run build && API_PLATFORM_CREATE_CLIENT_ENTRYPOINT=https://demo.api-platform.com API_PLATFORM_CREATE_CLIENT_OUTPUT=./tmp ./lib/index.js",
    "test-react-app": "./testapp.sh react",
    "test-next-app": "./testapp.sh next",
    "test-vue-app": "./testapp.sh vue",
    "test-nuxt-app": "./testapp.sh nuxt"
  },
  "lint-staged": {
    "src/**/*.js": "pnpm run fix"
  },
  "bin": {
    "create-client": "./lib/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "allowScripts": {
    "core-js-pure@3.49.0": true,
    "highlight.js@9.18.5": true,
    "nice-napi@1.0.2": true
  }
}
